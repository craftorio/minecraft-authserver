{
    "name": "craftorio/authserver",
    "description": "Craftorio Session Server",
    "type": "project",
    "require": {
        "php": "^8.4",
        "mikecao/flight": "^3.0",
        "justinrainbow/json-schema": "^5.2",
        "rakibtg/sleekdb": "^2.12",
        "php-di/php-di": "^7.0",
        "ramsey/uuid": "^4.7",
        "rych/phpass": "^2.0",
        "vlucas/phpdotenv": "^5.6",
        "hassankhan/config": "^3.0",
        "symfony/console": "^7.2",
        "nelexa/zip": "^4.0",
        "clancats/hydrahon": "^1.1"
    },
    "license": "MIT",
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Craftorio\\Authserver\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Craftorio\\Authserver\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "sergeycherepanov",
            "email": "sergey@cherepanov.org.ua"
        }
    ],
    "minimum-stability": "stable"
}
